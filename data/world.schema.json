{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beta-earth.local/schema/world-1.0.json",
  "title": "Beta Earth Clean Rebuild World",
  "type": "object",
  "required": [
    "schema_version",
    "title",
    "start_room",
    "rooms"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "start_room": {
      "type": "string",
      "minLength": 1
    },
    "rooms": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/room"
      }
    }
  },
  "$defs": {
    "flagList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interaction": {
      "type": "object",
      "required": [
        "id",
        "label",
        "command",
        "description",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999
        },
        "requires_flags": {
          "$ref": "#/$defs/flagList"
        },
        "grants_flags": {
          "$ref": "#/$defs/flagList"
        },
        "once": {
          "type": "boolean"
        }
      }
    },
    "room": {
      "type": "object",
      "required": [
        "name",
        "zone",
        "description",
        "exits",
        "interactions",
        "canon_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "zone": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "ambient": {
          "type": "string"
        },
        "danger": {
          "type": "string",
          "minLength": 1
        },
        "exits": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "north",
              "east",
              "south",
              "west",
              "up",
              "down"
            ]
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "canon_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "interactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interaction"
          }
        }
      }
    }
  }
}
